# ============================================================
#  OpenUI — Configuration
# ============================================================
# Enable AI providers by adding their API keys below.
# Every provider with a valid key will appear in the model
# selector dropdown. You can enable as many as you want.
# ============================================================

# --- REQUIRED: Fallback Model ---
# Format: provider/model-id
# Used when the selected model fails to respond.
NEXT_PUBLIC_OPENUI_FALLBACK_MODEL=openrouter/qwen/qwen3.7-plus

# --- OpenRouter (https://openrouter.ai) ---
OPENROUTER_API_KEY=

# --- NVIDIA NIM (https://build.nvidia.com) ---
NVIDIA_NIM_API_KEY=

# --- Ollama (https://ollama.com) ---
# Set OLLAMA_ENABLED=true if running Ollama locally
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic (https://console.anthropic.com) ---
ANTHROPIC_API_KEY=

# --- OpenAI (https://platform.openai.com) ---
OPENAI_API_KEY=

# --- Google AI (https://aistudio.google.com) ---
GEMINI_API_KEY=

# ============================================================
#  App
# ============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
